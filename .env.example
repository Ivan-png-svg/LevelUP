# -----------------------------------------------------------------------------
# LEVEL UP PROJECT - ENVIRONMENT VARIABLES CONFIGURATION
# -----------------------------------------------------------------------------
# ГАЙД З ПІДКЛЮЧЕННЯ БАЗИ ДАНИХ (AIVEN):
#
# 1. Створіть копію цього файлу та назвіть її просто .env
# 2. Переконайтеся, що файл ca.pem (SSL сертифікат) лежить у корені проекту.
# 3. Для Vercel: додайте DATABASE_URL у розділі Settings -> Environment Variables.
# -----------------------------------------------------------------------------

# Універсальне посилання (Рекомендовано для Vercel та Prisma)
# Формат: mysql://user:password@host:port/dbname?ssl-mode=REQUIRED
DATABASE_URL="url"

# --- Окремі параметри (якщо бекенд вимагає розбивки) ---
DB_USER=avnadmin
DB_PASSWORD=pass
DB_HOST=host
DB_PORT=port
DB_NAME=name

# --- Налаштування AI (Groq) ---
# Отримайте ключ на https://console.groq.com/
GROQ_API_KEY=your_api_key_here

# --- Flask Settings ---
FLASK_APP=app.py
FLASK_DEBUG=1
SECRET_KEY=generate_a_random_secret_key_for_session